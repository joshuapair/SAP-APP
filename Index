function initPad(id){
  var c=document.getElementById(id);if(!c)return;
  var ctx=c.getContext('2d'),drawing=false,lx=0,ly=0;
  function resize(){var r=window.devicePixelRatio||1,cur=c.toDataURL('image/png');c.width=c.offsetWidth*r;c.height=c.offsetHeight*r;ctx.setTransform(1,0,0,1,0,0);ctx.scale(r,r);ctx.lineWidth=2;ctx.lineCap='round';ctx.lineJoin='round';ctx.strokeStyle='#111';if(cur&&cur!=='data:,')drawPad(id,cur);}
  function pt(e){var r=c.getBoundingClientRect();return{x:e.clientX-r.left,y:e.clientY-r.top};}
  c.style.touchAction='none';
  c.addEventListener('pointerdown',function(e){drawing=true;var p=pt(e);lx=p.x;ly=p.y;});
  c.addEventListener('pointermove',function(e){if(!drawing)return;e.preventDefault();var p=pt(e);ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(p.x,p.y);ctx.stroke();lx=p.x;ly=p.y;});
  c.addEventListener('pointerup',function(){drawing=false;});
  c.addEventListener('pointerleave',function(){drawing=false;});
  c.addEventListener('pointercancel',function(){drawing=false;});
  resize();window.addEventListener('resize',resize);
}
function clearPad(id){var c=document.getElementById(id);if(c)c.getContext('2d').clearRect(0,0,c.width,c.height);}
function drawPad(id,url){var c=document.getElementById(id);if(!c)return;var ctx=c.getContext('2d'),img=new Image();img.onload=function(){ctx.clearRect(0,0,c.width,c.height);ctx.drawImage(img,0,0,c.width/(window.devicePixelRatio||1),c.height/(window.devicePixelRatio||1));};img.src=url;}

document.addEventListener('DOMContentLoaded',function(){
  buildTbls();initPad('sigIni');initPad('sigFU');
  var rb=document.querySelector('[name="sapRecommendation"]');
  if(rb){rb.dataset.ue='false';rb.addEventListener('input',function(){rb.dataset.ue=rb.value.trim()?'true':'false';});}
  syncRec();calcAll();buildRpt();
  google.script.run
    .withSuccessHandler(function(res){iniRecs=res.initial||[];fuRecs=res.followup||[];fillLinkSel();})
    .withFailureHandler(function(){})
    .getAllRecords();
});
</script>
