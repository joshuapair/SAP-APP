<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ARS SAP EHR</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0d1f3c;--navy2:#1a3560;--navy3:#243f72;
  --gold:#c9a84c;--gold2:#e8d9a8;--gold3:#faf6ec;
  --bg:#f0f2f8;--card:#fff;--line:#dde2ec;--lined:#b8c0d0;
  --text:#0d1f3c;--muted:#6b7a99;--soft:#f8f9fc;
  --red:#8b1a1a;--green:#1a4a2e;--amber:#6b4400;
  --r:6px;--rl:12px;
  --sh:0 2px 12px rgba(13,31,60,.08);
  --shl:0 6px 28px rgba(13,31,60,.14);
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-size:14px;line-height:1.6;}
body{padding-bottom:80px;}
.wrap{max-width:1200px;margin:0 auto;padding:0 22px;}
.appbar{background:var(--navy);display:flex;align-items:center;justify-content:space-between;padding:0 24px;border-bottom:3px solid var(--gold);position:sticky;top:0;z-index:2000;isolation:isolate;box-shadow:0 2px 20px rgba(0,0,0,.3);}
.brand{display:flex;align-items:center;gap:14px;padding:11px 0;}
.brand-icon{width:44px;height:44px;background:var(--gold);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.brand h1{font-family:'Playfair Display',serif;font-size:17px;color:#fff;font-weight:700;}
.brand p{font-size:10px;color:var(--gold2);letter-spacing:.14em;text-transform:uppercase;font-weight:500;margin-top:1px;}
.appnav{display:flex;gap:2px;}
.ntab{padding:10px 20px;border:0;background:transparent;color:rgba(255,255,255,.5);font-family:'Inter',sans-serif;font-weight:600;font-size:11px;letter-spacing:.05em;text-transform:uppercase;cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;}
.ntab:hover{color:#fff;background:rgba(255,255,255,.07);}
.ntab.on{color:var(--gold);border-bottom-color:var(--gold);background:rgba(201,168,76,.1);}
.toolbar{background:var(--navy2);padding:6px 12px;display:grid;grid-auto-flow:column;grid-auto-columns:max-content;gap:5px;align-items:center;position:sticky;top:67px;z-index:1000;overflow-x:auto;overflow-y:visible;scrollbar-width:none;-webkit-overflow-scrolling:touch;}
.toolbar::-webkit-scrollbar{display:none;}
btn,button{font-family:'Inter',sans-serif;font-weight:600;font-size:11px;cursor:pointer;border:0;border-radius:var(--r);padding:6px 11px;transition:all .15s;letter-spacing:.02em;white-space:nowrap;}
button.p{background:var(--gold);color:var(--navy);}button.p:hover{background:#b8963e;}
button.s{background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.2);}button.s:hover{background:rgba(255,255,255,.25);}
button.g{background:rgba(255,255,255,.07);color:rgba(255,255,255,.8);border:1px solid rgba(255,255,255,.15);}button.g:hover{background:rgba(255,255,255,.15);}
button.d{background:var(--red);color:#fff;}button.d:hover{background:#6a1010;}
button.ok{background:var(--green);color:#fff;}button.ok:hover{background:#133820;}
button.nv{background:var(--navy);color:#fff;border:1px solid var(--navy3);}button.nv:hover{background:var(--navy3);}
button:disabled{opacity:.4;cursor:not-allowed;}
.stxt{color:rgba(255,255,255,.5);font-size:10px;margin-left:4px;font-style:italic;white-space:nowrap;flex-shrink:0;}
.pg{display:none;}.pg.on{display:block;}
.card{background:var(--card);border:1px solid var(--line);border-radius:var(--rl);padding:24px 28px;margin-bottom:18px;box-shadow:var(--sh);}
.lhcard{background:var(--navy);border-radius:var(--rl);margin-bottom:18px;box-shadow:var(--shl);overflow:hidden;position:relative;}
.lhcard::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--gold),var(--gold2),var(--gold));}
.lhin{padding:30px 36px;display:flex;justify-content:space-between;align-items:flex-start;gap:20px;}
.lhl h1{font-family:'Playfair Display',serif;font-size:27px;font-weight:800;color:#fff;margin:0 0 5px;}
.lhsub{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;}
.lhd{font-size:12px;color:rgba(255,255,255,.55);}.lhd span{color:rgba(255,255,255,.85);font-weight:600;}
.lha{font-size:12px;color:rgba(255,255,255,.4);margin-top:7px;line-height:1.75;}
.lhr{text-align:right;flex-shrink:0;}
.lhbadge{background:rgba(201,168,76,.15);border:1px solid rgba(201,168,76,.35);border-radius:10px;padding:14px 22px;display:inline-block;}
.lhbl{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);font-weight:700;}
.lhbv{font-size:15px;color:#fff;font-weight:700;margin-top:3px;}
.lhconf{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-top:10px;}
.stitle{display:flex;justify-content:space-between;align-items:center;border-bottom:2px solid var(--gold3);padding-bottom:12px;margin-bottom:20px;}
.stitle h2{margin:0;font-size:11px;font-weight:700;color:var(--navy);letter-spacing:.1em;text-transform:uppercase;display:flex;align-items:center;gap:8px;}
.stitle h2::before{content:'';width:3px;height:14px;background:var(--gold);border-radius:2px;display:inline-block;flex-shrink:0;}
.stitle small{color:var(--muted);font-size:10px;letter-spacing:.1em;text-transform:uppercase;font-weight:600;}
.g{display:grid;gap:16px;}.g2{grid-template-columns:repeat(2,minmax(0,1fr));}.g3{grid-template-columns:repeat(3,minmax(0,1fr));}.g4{grid-template-columns:repeat(4,minmax(0,1fr));}.mt{margin-top:16px;}
.f label,.f legend{display:block;font-weight:600;font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
.f input[type=text],.f input[type=date],.f input[type=number],.f textarea,.f select{width:100%;border:1.5px solid var(--lined);border-radius:var(--r);padding:9px 12px;font-size:14px;font-family:'Inter',sans-serif;background:#fff;color:var(--text);transition:border-color .12s,box-shadow .12s;}
.f input:focus,.f textarea:focus,.f select:focus{outline:none;border-color:var(--navy);box-shadow:0 0 0 3px rgba(13,31,60,.1);}
.f textarea{min-height:90px;resize:vertical;line-height:1.5;}
.f input[readonly]{background:var(--soft);color:var(--muted);}
fieldset.f{border:1.5px solid var(--line);border-radius:var(--rl);padding:14px 16px;}
.cg,.rg{display:grid;gap:8px 12px;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));}
.cg.c,.rg.c{grid-template-columns:repeat(auto-fit,minmax(100px,1fr));}
.opt{display:flex;gap:8px;align-items:flex-start;font-size:13px;cursor:pointer;}
.opt input{margin-top:3px;accent-color:var(--navy);}
.scorebox{background:linear-gradient(135deg,var(--navy),var(--navy2));border-radius:var(--rl);padding:22px;}
.sgrid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;}
.si{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:var(--r);padding:16px;}
.si .sl{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gold2);}
.si strong{display:block;font-size:30px;font-weight:800;color:var(--gold);margin:4px 0 2px;}
.rg2{color:#6fcf8a;font-weight:700;font-size:12px;}.rw{color:#f6c94e;font-weight:700;font-size:12px;}.rb{color:#f4786a;font-weight:700;font-size:12px;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th,td{border:1px solid var(--line);padding:9px 12px;vertical-align:top;}
th{background:var(--navy);color:rgba(255,255,255,.8);font-weight:700;font-size:10px;letter-spacing:.08em;text-transform:uppercase;}
tr:nth-child(even) td{background:#fafbfd;}
.it td:first-child{width:36px;text-align:center;font-weight:800;color:var(--navy);}
.it td:nth-child(3),.it td:nth-child(4){width:60px;text-align:center;}
.it td:last-child{width:110px;color:var(--muted);font-size:11px;}
.rprev{white-space:pre-wrap;background:var(--soft);border:1.5px solid var(--line);border-radius:var(--r);padding:24px;min-height:180px;font-size:13.5px;line-height:1.8;font-family:'Inter',sans-serif;}
.sigpad{border:1.5px solid var(--lined);border-radius:var(--r);background:#fff;width:100%;height:155px;display:block;}
.subtle{background:var(--gold3);border:1px solid var(--gold2);border-left:3px solid var(--gold);border-radius:var(--r);padding:14px 16px;font-size:13px;line-height:1.7;white-space:pre-wrap;}
.dvd{display:flex;align-items:center;gap:12px;margin:22px 0 16px;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);}
.dvd::before,.dvd::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--gold2),transparent);}
.dvd::after{background:linear-gradient(270deg,var(--gold2),transparent);}
.fnote{font-size:12px;color:var(--muted);line-height:1.6;margin-top:16px;padding-top:16px;border-top:1px solid var(--line);}
.dashhero{background:linear-gradient(135deg,var(--navy),var(--navy2));border-radius:var(--rl);padding:30px 36px;margin-bottom:20px;box-shadow:var(--shl);position:relative;overflow:hidden;}
.dashhero::after{content:'⚕';position:absolute;right:36px;top:50%;transform:translateY(-50%);font-size:88px;opacity:.05;}
.dashhero h2{font-family:'Playfair Display',serif;font-size:26px;color:#fff;margin-bottom:6px;}
.dashhero p{color:rgba(255,255,255,.4);font-size:13px;}
.dstats{display:flex;gap:14px;margin-top:20px;flex-wrap:wrap;}
.dstat{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:var(--r);padding:14px 22px;flex:1;min-width:110px;}
.dsl{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);}
.dsv{font-size:28px;font-weight:800;color:#fff;margin-top:3px;}
.sbar{position:relative;margin-bottom:16px;}
.sbar input{width:100%;padding:11px 16px 11px 42px;border:1.5px solid var(--lined);border-radius:var(--r);font-family:'Inter',sans-serif;font-size:14px;background:#fff;}
.sbar input:focus{outline:none;border-color:var(--navy);box-shadow:0 0 0 3px rgba(13,31,60,.1);}
.sbar::before{content:'🔍';position:absolute;left:14px;top:50%;transform:translateY(-50%);}
.cgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px;}
.ccard{background:#fff;border:1.5px solid var(--line);border-radius:var(--rl);padding:20px;cursor:pointer;transition:all .15s;box-shadow:var(--sh);}
.ccard:hover{border-color:var(--navy);box-shadow:var(--shl);transform:translateY(-2px);}
.ccn{font-size:17px;font-weight:700;color:var(--navy);margin-bottom:4px;}
.ccm{font-size:12px;color:var(--muted);display:flex;flex-wrap:wrap;gap:5px 14px;margin-bottom:12px;}
.ccr{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;}
.rbadge{padding:4px 10px;border-radius:20px;font-size:10px;font-weight:700;letter-spacing:.05em;cursor:pointer;transition:all .15s;}
.rbadge.ini{background:#e8f0fe;color:#1a56c4;border:1px solid #c5d8fc;}.rbadge.ini:hover{background:#1a56c4;color:#fff;}
.rbadge.fu{background:#e8fef0;color:#1a7a40;border:1px solid #b8f0cc;}.rbadge.fu:hover{background:#1a7a40;color:#fff;}
.cca{display:flex;gap:6px;}
.ccbtn{flex:1;padding:7px;font-size:11px;border-radius:var(--r);border:1.5px solid var(--line);background:var(--soft);color:var(--navy);font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;transition:all .15s;}
.ccbtn:hover{background:var(--navy);color:#fff;border-color:var(--navy);}
.ccbtn.del{color:var(--red);}.ccbtn.del:hover{background:var(--red);color:#fff;border-color:var(--red);}
.empty{text-align:center;padding:60px 20px;color:var(--muted);}
.empty .ei{font-size:48px;margin-bottom:14px;}
.empty h3{margin-bottom:6px;font-size:18px;color:var(--navy);}
.moverlay{display:none;position:fixed;inset:0;background:rgba(13,31,60,.65);z-index:9000;align-items:center;justify-content:center;padding:20px;}
.moverlay.on{display:flex;}
.modal{background:#fff;border-radius:var(--rl);max-width:920px;width:100%;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(13,31,60,.35);}
.mhead{background:var(--navy);padding:20px 28px;display:flex;justify-content:space-between;align-items:flex-start;border-radius:var(--rl) var(--rl) 0 0;position:sticky;top:0;z-index:1;}
.mhead h3{font-family:'Playfair Display',serif;font-size:20px;color:#fff;margin-bottom:2px;}
.mhead .msub{font-size:11px;color:rgba(255,255,255,.45);}
.mclose{background:rgba(255,255,255,.1);border:none;color:#fff;width:34px;height:34px;border-radius:50%;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.mclose:hover{background:rgba(255,255,255,.2);}
.mbody{padding:28px;}
.mtabs{display:flex;gap:4px;margin-bottom:20px;border-bottom:2px solid var(--line);padding-bottom:0;}
.mtab{padding:8px 18px;border:0;border-radius:var(--r) var(--r) 0 0;font-family:'Inter',sans-serif;font-weight:600;font-size:12px;cursor:pointer;letter-spacing:.04em;text-transform:uppercase;background:transparent;color:var(--muted);border-bottom:2px solid transparent;margin-bottom:-2px;position:relative;z-index:10;pointer-events:all;user-select:none;}
.mtab.on{color:var(--navy);border-bottom-color:var(--gold);background:var(--gold3);}
.mrep{white-space:pre-wrap;background:var(--soft);border:1px solid var(--line);border-radius:var(--r);padding:22px;font-size:13px;line-height:1.85;font-family:'Inter',sans-serif;max-height:55vh;overflow-y:auto;}
.mmeta{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px;}
.mi{background:var(--soft);border-radius:var(--r);padding:12px 16px;}
.mil{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.miv{font-size:14px;font-weight:600;color:var(--navy);margin-top:3px;}
.mtc{display:none;}.mtc.on{display:block;}
.inl{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.hp{display:block;}.pn{display:none;}.pb{page-break-before:always;break-before:page;}
@media(max-width:860px){.g2,.g3,.g4,.sgrid,.mmeta{grid-template-columns:1fr;}.appnav .ntab{padding:10px 12px;font-size:10px;}}
@media print{
  @page{size:letter;margin:.5in;}
  body{background:#fff;padding:0;font-size:12px;}
  .appbar,.toolbar,.hp,#dashPg,#fupPg{display:none!important;}
  .card{box-shadow:none;border-radius:0;border:1px solid #ccc;margin-bottom:12px;padding:14px;}
  .lhcard{background:#0d1f3c!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .scorebox{background:#0d1f3c!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .pn{display:block;}
}
</style>
</head>
<body>

<div class="appbar">
  <div class="brand">
    <div class="brand-icon">⚕</div>
    <div>
      <h1>Addiction Recovery Solutions, PLLC</h1>
      <p>SAP Electronic Health Record · 903.445.8953</p>
    </div>
  </div>
  <nav class="appnav">
    <button class="ntab on" id="tabIni" onclick="showPg('ini')">Initial Evaluation</button>
    <button class="ntab" id="tabFup" onclick="showPg('fup')">Follow-Up Evaluation</button>
    <button class="ntab" id="tabDash" onclick="showPg('dash')">Client Records</button>
  </nav>
</div>

<!-- ═══════ INITIAL EVAL ═══════ -->
<div id="iniPg" class="pg on">
  <div class="toolbar hp">
    <div style="display:inline-flex;flex-wrap:nowrap;gap:5px;align-items:center;width:max-content">
      <button class="s" onclick="buildRpt()">📄 Build Report</button>
      <button class="g" onclick="saveD()">💾 Save Draft</button>
      <button class="g" onclick="loadD()">📂 Load Draft</button>
      <button class="d" onclick="clearIni()">🗑 Clear</button>
      <button class="g" onclick="window.print()">🖨 Print</button>
      <button class="ok" id="shBtn" onclick="saveSheets()">☁ Save to Sheets</button>
      <span class="stxt" id="sst">Ready.</span>
    </div>
  </div>
  <div class="wrap" style="padding-top:20px">
  <form id="iniForm">

    <div class="lhcard">
      <div class="lhin">
        <div class="lhl">
          <div class="lhsub">Substance Abuse Professional · Initial SAP Evaluation</div>
          <h1>Addiction Recovery Solutions, PLLC</h1>
          <div class="lhd"><span>Joshua Pair</span>, M.Ed., LCDC, SAP · DOT-Qualified SAP · 49 CFR Part 40</div>
          <div class="lha">410 Rocket St. · Longview, TX 75603 · 903.445.8953</div>
        </div>
        <div class="lhr">
          <div class="lhbadge"><div class="lhbl">Document Type</div><div class="lhbv">Initial SAP Evaluation</div></div>
          <div class="lhconf">Confidential</div>
          <p class="pn" style="font-size:11px;color:rgba(255,255,255,.4);margin-top:8px;">Print → Save as PDF</p>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="stitle"><h2>Client &amp; Referral Information</h2><small>Header</small></div>
      <div class="g g4">
        <div class="f"><label>Client Name</label><input name="clientName" type="text"></div>
        <div class="f"><label>Evaluation Date</label><input name="evalDate" type="date"></div>
        <div class="f"><label>SSN</label><input name="ssn" type="text"></div>
        <div class="f"><label>Date of Birth</label><input name="dob" type="date"></div>
      </div>
      <div class="g g3 mt">
        <fieldset class="f"><legend>Signed Paperwork</legend>
          <div class="cg c">
            <label class="opt"><input type="checkbox" name="docsSigned" value="Statement of Understanding"> Statement of Understanding</label>
            <label class="opt"><input type="checkbox" name="docsSigned" value="Consent/ROI"> Consent / ROI</label>
            <label class="opt"><input type="checkbox" name="docsSigned" value="Other"> Other</label>
          </div>
        </fieldset>
        <div class="f"><label>Other Paperwork Details</label><input name="docsOther" type="text"></div>
        <div class="f"><label>Case / Reference #</label><input name="caseNumber" type="text"></div>
      </div>
    </div>

    <div class="card">
      <div class="stitle"><h2>Assessment Reason / Test / Industry</h2><small>Core Logic</small></div>
      <div class="g g2">
        <fieldset class="f"><legend>Reason for Assessment</legend>
          <div class="rg">
            <label class="opt"><input type="radio" name="reason" value="Positive Test" onchange="buildRpt()"> Positive Test</label>
            <label class="opt"><input type="radio" name="reason" value="Self Referral" onchange="buildRpt()"> Self Referral</label>
            <label class="opt"><input type="radio" name="reason" value="DWI/DUI" onchange="buildRpt()"> DWI/DUI</label>
            <label class="opt"><input type="radio" name="reason" value="Random Selection" onchange="buildRpt()"> Random Selection</label>
            <label class="opt"><input type="radio" name="reason" value="Reasonable Suspicion" onchange="buildRpt()"> Reasonable Suspicion</label>
            <label class="opt"><input type="radio" name="reason" value="Follow Up" onchange="buildRpt()"> Follow Up</label>
            <label class="opt"><input type="radio" name="reason" value="Post Accident" onchange="buildRpt()"> Post Accident</label>
            <label class="opt"><input type="radio" name="reason" value="Return to Duty" onchange="buildRpt()"> Return to Duty</label>
            <label class="opt"><input type="radio" name="reason" value="Pre-employment" onchange="buildRpt()"> Pre-employment</label>
            <label class="opt"><input type="radio" name="reason" value="Not Applicable" onchange="buildRpt()"> Not Applicable</label>
          </div>
        </fieldset>
        <div class="g g2">
          <div class="f"><label>Violation Date</label><input name="positiveTestDate" type="date" oninput="buildRpt()"></div>
          <div class="f"><label>Type of Test</label><input name="typeOfTest" type="text" placeholder="Urine, BAT, Oral Fluid…" oninput="buildRpt()"></div>
          <div class="f"><label>Reason Details</label><input name="reasonNotes" type="text" oninput="buildRpt()"></div>
          <div class="f"><label>Current Employer / Entity</label><input name="employer" type="text" oninput="buildRpt()"></div>
        </div>
      </div>
      <div class="g g2 mt">
        <fieldset class="f"><legend>Industry Type</legend>
          <div class="rg">
            <label class="opt"><input type="radio" name="industry" value="FMCSA" onchange="buildRpt()"> FMCSA</label>
            <label class="opt"><input type="radio" name="industry" value="FAA" onchange="buildRpt()"> FAA</label>
            <label class="opt"><input type="radio" name="industry" value="FRA" onchange="buildRpt()"> FRA</label>
            <label class="opt"><input type="radio" name="industry" value="FTA" onchange="buildRpt()"> FTA</label>
            <label class="opt"><input type="radio" name="industry" value="USCG" onchange="buildRpt()"> USCG</label>
            <label class="opt"><input type="radio" name="industry" value="PHMSA" onchange="buildRpt()"> PHMSA</label>
            <label class="opt"><input type="radio" name="industry" value="Non-Transportation" onchange="buildRpt()"> Non-Transportation</label>
            <label class="opt"><input type="radio" name="industry" value="Other" onchange="buildRpt()"> Other Position</label>
          </div>
        </fieldset>
        <div class="f"><label>Other Position / Industry</label><input name="otherPosition" type="text" oninput="buildRpt()"></div>
      </div>
