  return o;
}

function calcMAST(){
  var t=0;MAST.forEach(function(i){var v=rv('mast_'+i.n);if(v==='yes')t+=i.yes;if(v==='no')t+=i.no;});
  var s,c;if(t<=3){s='Probably no drug/alcohol addiction';c='rg2';}else if(t===4){s='Borderline drug/alcohol addiction';c='rw';}else{s='Probably drug/alcohol addiction';c='rb';}
  document.getElementById('mastSc').textContent=t;var mi=document.getElementById('mastIn');mi.textContent=s;mi.className=c;
  return{total:t,interpretation:s};
}
function calcDAST(){
  var t=0;DAST.forEach(function(i){var v=rv('dast_'+i.n);if(!v)return;t+=i.ry?(v==='yes'?1:0):(v==='no'?1:0);});
  var s,c;if(t===0){s='No problems reported';c='rg2';}else if(t<=2){s='Low level';c='rg2';}else if(t<=5){s='Moderate level';c='rw';}else if(t<=8){s='Substantial level';c='rb';}else{s='Severe level';c='rb';}
  document.getElementById('dastSc').textContent=t;var di=document.getElementById('dastIn');di.textContent=s;di.className=c;
  return{total:t,interpretation:s};
}
function calcAll(){
  var m=calcMAST(),d=calcDAST(),fl,nt;
  if(m.total>=5||d.total>=6){fl='High Concern';nt='Scores suggest clinically significant substance-related risk.';}
  else if(m.total===4||(d.total>=3&&d.total<=5)){fl='Moderate Concern';nt='Scores show a meaningful risk pattern; integrate into evaluation.';}
