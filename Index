function fobj(fid){
  var fo=new FormData(document.getElementById(fid)),o={};
  for(var p of fo.entries()){var k=p[0],v=p[1];if(o[k]){if(!Array.isArray(o[k]))o[k]=[o[k]];o[k].push(v);}else o[k]=v;}
